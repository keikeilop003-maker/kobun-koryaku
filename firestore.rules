rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isValidStudentCode(code) {
      return code is string && code.matches('^1[A-H][0-9]{2}$');
    }

    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    match /users/{uid}/account/main {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'lastSeenAt',
          'requestedStudentCode',
          'studentCodeStatus',
          'requestedAt',
          'registrationCompleted',
          'registeredAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (
          !request.resource.data.keys().hasAny(['requestedStudentCode'])
          || isValidStudentCode(request.resource.data.requestedStudentCode)
        )
        && (
          !request.resource.data.keys().hasAny(['studentCodeStatus'])
          || request.resource.data.studentCodeStatus == 'requested'
        )
        && (
          !request.resource.data.keys().hasAny(['registrationCompleted'])
          || request.resource.data.registrationCompleted == true
        );
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'email',
          'displayName',
          'lastSeenAt',
          'requestedStudentCode',
          'studentCodeStatus',
          'requestedAt',
          'registrationCompleted',
          'registeredAt'
        ])
        && (
          !request.resource.data.keys().hasAny(['requestedStudentCode'])
          || isValidStudentCode(request.resource.data.requestedStudentCode)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['studentCodeStatus'])
          || request.resource.data.studentCodeStatus == 'requested'
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['registrationCompleted'])
          || request.resource.data.registrationCompleted == true
        );
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentCode',
          'studentCodeStatus',
          'studentCodeReviewedAt',
          'studentCodeReviewedBy',
          'studentCodeReviewedByEmail'
        ])
        && isValidStudentCode(request.resource.data.studentCode)
        && request.resource.data.studentCodeStatus in ['approved', 'rejected', 'requested'];
      allow delete: if false;
    }
    match /users/{uid}/profile/main {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }
    match /users/{uid}/history/{textId} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }
    match /whispers/{whisperId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['textId','questionId','questionTitle','text','avatarSeed','createdAt'])
        && request.resource.data.text.size() <= 200;
      allow update, delete: if false;
    }
    match /analysisPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.text.size() <= 500;
      allow update, delete: if false;
    }
    match /analysisReactions/{reactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }
    match /analysisThemes/{textId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /appSettings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && (
          (
            settingId == 'textbookOrder'
            && request.resource.data.keys().hasOnly([
              'order',
              'updatedBy',
              'updatedByEmail',
              'updatedAt'
            ])
            && request.resource.data.order is list
          )
          ||
          (
            settingId == 'textbookStatus'
            && request.resource.data.keys().hasOnly([
              'statuses',
              'updatedBy',
              'updatedByEmail',
              'updatedAt'
            ])
            && request.resource.data.statuses is map
          )
        )
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email;
    }
    match /adminMessages/{messageId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'text',
          'status',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'open'
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['open', 'working', 'closed'];
      allow delete: if false;
    }
    match /customTargets/{targetId} {
      allow read: if request.auth != null;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'target',
          'anchor',
          'createdBy',
          'createdByEmail',
          'createdAt'
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.target is map
        && request.resource.data.anchor is map;
      allow update, delete: if isAdmin();
    }
    match /hiddenTargets/{targetId} {
      allow read: if request.auth != null;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'targetId',
          'hiddenBy',
          'hiddenByEmail',
          'createdAt'
        ])
        && request.resource.data.hiddenBy == request.auth.uid
        && request.resource.data.hiddenByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.targetId is string;
      allow update, delete: if isAdmin();
    }
    match /editedTargets/{targetId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'targetId',
          'target',
          'anchor',
          'updatedBy',
          'updatedByEmail',
          'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.targetId is string
        && request.resource.data.target is map
        && request.resource.data.anchor is map;
      allow delete: if isAdmin();
    }
    match /editedNormalQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'questionId',
          'question',
          'updatedBy',
          'updatedByEmail',
          'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.questionId is string
        && request.resource.data.question is string
        && request.resource.data.question.size() <= 1000;
      allow delete: if isAdmin();
    }
  }
}
