rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function isValidStudentCode(code) {
      return code is string && code.matches('^1[A-H][0-9]{2}$');
    }
    function isValidLoginId(loginId) {
      return loginId is string && loginId.matches('^[a-z0-9._-]{3,32}$');
    }
    function isValidPublicProfile(data) {
      return (
        !data.keys().hasAny(['username'])
        || (data.username is string && data.username.size() <= 24)
      )
      && (
        !data.keys().hasAny(['bio'])
        || (data.bio is string && data.bio.size() <= 80)
      );
    }

    match /admins/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    match /users/{uid}/account/main {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'loginId',
          'username',
          'bio',
          'lastSeenAt',
          'publicProfileUpdatedAt',
          'requestedStudentCode',
          'studentCodeStatus',
          'requestedAt',
          'registrationCompleted',
          'registeredAt'
        ])
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (
          !request.resource.data.keys().hasAny(['loginId'])
          || isValidLoginId(request.resource.data.loginId)
        )
        && isValidPublicProfile(request.resource.data)
        && (
          !request.resource.data.keys().hasAny(['requestedStudentCode'])
          || isValidStudentCode(request.resource.data.requestedStudentCode)
        )
        && (
          !request.resource.data.keys().hasAny(['studentCodeStatus'])
          || request.resource.data.studentCodeStatus == 'requested'
        )
        && (
          !request.resource.data.keys().hasAny(['registrationCompleted'])
          || request.resource.data.registrationCompleted == true
        );
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'email',
          'displayName',
          'loginId',
          'username',
          'bio',
          'lastSeenAt',
          'publicProfileUpdatedAt',
          'requestedStudentCode',
          'studentCodeStatus',
          'requestedAt',
          'registrationCompleted',
          'registeredAt'
        ])
        && isValidPublicProfile(request.resource.data)
        && (
          !request.resource.data.keys().hasAny(['loginId'])
          || isValidLoginId(request.resource.data.loginId)
        )
        && (
          !request.resource.data.keys().hasAny(['requestedStudentCode'])
          || isValidStudentCode(request.resource.data.requestedStudentCode)
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['studentCodeStatus'])
          || request.resource.data.studentCodeStatus == 'requested'
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['registrationCompleted'])
          || request.resource.data.registrationCompleted == true
        );
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'studentCode',
          'studentCodeStatus',
          'studentCodeReviewedAt',
          'studentCodeReviewedBy',
          'studentCodeReviewedByEmail'
        ])
        && isValidStudentCode(request.resource.data.studentCode)
        && request.resource.data.studentCodeStatus in ['approved', 'rejected', 'requested'];
      allow delete: if false;
    }
    match /users/{uid}/profile/main {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }
    match /users/{uid}/history/{textId} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }
    match /{path=**}/account/{accountId} {
      allow read: if isAdmin();
    }
    match /{path=**}/profile/{profileId} {
      allow read: if isAdmin();
    }
    match /{path=**}/history/{historyId} {
      allow read: if isAdmin();
    }
    match /whispers/{whisperId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['textId','questionId','questionTitle','text','avatarSeed','createdAt'])
        && request.resource.data.text.size() <= 200;
      allow update, delete: if false;
    }
    match /analysisPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'textId',
          'themeId',
          'text',
          'authorUid',
          'avatarSeed',
          'equipped',
          'replyTo',
          'replyToText',
          'replyToAvatarSeed',
          'pinnedByOwner',
          'pinnedByAdmin',
          'createdAt'
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.textId is string
        && request.resource.data.themeId is string
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500
        && request.resource.data.avatarSeed is string
        && request.resource.data.pinnedByOwner == false
        && request.resource.data.pinnedByAdmin == false
        && (
          !request.resource.data.keys().hasAny(['replyTo'])
          || (
            request.resource.data.replyTo is string
            && request.resource.data.replyToText is string
            && request.resource.data.replyToText.size() <= 80
            && request.resource.data.replyToAvatarSeed is string
          )
        );
      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinnedByOwner', 'updatedAt'])
        && request.resource.data.pinnedByOwner is bool;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'pinnedByAdmin',
          'pinnedByOwner',
          'correction',
          'editedAt',
          'editedBy',
          'updatedAt'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['text'])
          || (
            request.resource.data.text is string
            && request.resource.data.text.size() <= 500
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['editedBy'])
          || request.resource.data.editedBy == request.auth.uid
        );
      allow delete: if isAdmin();
    }
    match /analysisReactions/{reactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['textId','postId','authorUid','type','createdAt'])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.textId is string
        && request.resource.data.postId is string
        && request.resource.data.type in ['like'];
      allow delete: if isAdmin() || (request.auth != null && resource.data.authorUid == request.auth.uid);
      allow update: if false;
    }
    match /analysisThemes/{textId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    match /appSettings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin()
        && (
          (
            settingId == 'textbookOrder'
            && request.resource.data.keys().hasOnly([
              'order',
              'updatedBy',
              'updatedByEmail',
              'updatedAt'
            ])
            && request.resource.data.order is list
          )
          ||
          (
            settingId == 'textbookStatus'
            && request.resource.data.keys().hasOnly([
              'statuses',
              'updatedBy',
              'updatedByEmail',
              'updatedAt'
            ])
            && request.resource.data.statuses is map
          )
          ||
          (
            settingId == 'information'
            && request.resource.data.keys().hasOnly([
              'title',
              'body',
              'updatedBy',
              'updatedByEmail',
              'updatedAt'
            ])
            && request.resource.data.title is string
            && request.resource.data.title.size() <= 80
            && request.resource.data.body is string
            && request.resource.data.body.size() <= 1000
          )
        )
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email;
    }
    match /userInboxMessages/{messageId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'loginId',
          'displayName',
          'title',
          'body',
          'status',
          'createdAt',
          'createdBy',
          'createdByEmail'
        ])
        && request.resource.data.uid is string
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 80
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 1000
        && request.resource.data.status == 'unread'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt'])
        && request.resource.data.status in ['unread', 'read'];
      allow update: if request.auth != null
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'readAt'])
        && request.resource.data.status == 'read';
      allow delete: if false;
    }
    match /adminMessages/{messageId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'loginId',
          'text',
          'status',
          'createdAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          !request.resource.data.keys().hasAny(['loginId'])
          || isValidLoginId(request.resource.data.loginId)
        )
        && request.resource.data.status == 'open'
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 500;
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['open', 'working', 'closed'];
      allow delete: if false;
    }
    match /customTargets/{targetId} {
      allow read: if request.auth != null;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'target',
          'anchor',
          'createdBy',
          'createdByEmail',
          'createdAt'
        ])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.target is map
        && request.resource.data.anchor is map;
      allow update, delete: if isAdmin();
    }
    match /hiddenTargets/{targetId} {
      allow read: if request.auth != null;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'targetId',
          'hiddenBy',
          'hiddenByEmail',
          'createdAt'
        ])
        && request.resource.data.hiddenBy == request.auth.uid
        && request.resource.data.hiddenByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.targetId is string;
      allow update, delete: if isAdmin();
    }
    match /editedTargets/{targetId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'targetId',
          'target',
          'anchor',
          'updatedBy',
          'updatedByEmail',
          'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.targetId is string
        && request.resource.data.target is map
        && request.resource.data.anchor is map;
      allow delete: if isAdmin();
    }
    match /editedSections/{sectionId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'sectionId',
          'section',
          'updatedBy',
          'updatedByEmail',
          'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.sectionId is string
        && request.resource.data.section is map
        && request.resource.data.section.keys().hasOnly(['text', 'kundoku', 'notes', 'kanbunSyntax'])
        && request.resource.data.section.text is string
        && request.resource.data.section.text.size() <= 20000
        && request.resource.data.section.kundoku is string
        && request.resource.data.section.kundoku.size() <= 20000
        && request.resource.data.section.notes is string
        && request.resource.data.section.notes.size() <= 20000
        && request.resource.data.section.kanbunSyntax is string
        && request.resource.data.section.kanbunSyntax.size() <= 20000;
      allow delete: if isAdmin();
    }
    match /editedNormalQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasOnly([
            'textId',
            'questionId',
            'question',
            'answer',
            'alternativeAnswers',
            'updatedBy',
            'updatedByEmail',
            'updatedAt'
        ])
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedByEmail == request.auth.token.email
          && request.resource.data.textId is string
          && request.resource.data.questionId is string
          && request.resource.data.question is string
          && request.resource.data.question.size() <= 1000
          && (
            !request.resource.data.keys().hasAny(['answer'])
            || (
              request.resource.data.answer is string
              && request.resource.data.answer.size() <= 2000
            )
          )
          && (
            !request.resource.data.keys().hasAny(['alternativeAnswers'])
            || (
              request.resource.data.alternativeAnswers is list
              && request.resource.data.alternativeAnswers.size() <= 5
            )
          );
      allow delete: if isAdmin();
    }
    match /hiddenNormalQuestions/{questionId} {
      allow read: if request.auth != null;
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
          'textId',
          'questionId',
          'hiddenBy',
          'hiddenByEmail',
          'createdAt'
        ])
        && request.resource.data.hiddenBy == request.auth.uid
        && request.resource.data.hiddenByEmail == request.auth.token.email
        && request.resource.data.textId is string
        && request.resource.data.questionId is string;
      allow update, delete: if isAdmin();
    }
  }
}
